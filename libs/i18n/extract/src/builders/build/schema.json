{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://json-schema.org/draft-07/schema",
  "title": "Build builder",
  "description": "",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What is the name of the project to extract translations?"
    },
    "framework": {
      "description": "Add tags to the project (used for linting)",
      "type": "string",
      "alias": "f",
      "default": "react"
    },
    "directory": {
      "type": "string",
      "description": "A directory where the project is placed",
      "alias": "d",
      "default": "i18n"
    },
    "locales": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "A directory where the project is placed",
      "alias": "l"
    }
  },
  "required": [
    "project",
    "directory"
  ]
}