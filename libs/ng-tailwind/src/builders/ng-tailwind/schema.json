{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://json-schema.org/draft-07/schema",
  "title": "NgTailwind builder",
  "description": "",
  "type": "object",
  "properties": {
    "watch": {
      "type": "boolean",
      "description": "Recompile and run ng-tailwind when files change."
    },
    "configPath": {
      "type": "string",
      "description": "path to the ng-tailwind.js"
    },
    "purge": {
      "type": "boolean",
      "description": "Remove not used style code"
    },
    "devServerTarget": {
      "type": "string",
      "description": "Dev server target to run after watch files."
    }
  },
  "required": []
}
