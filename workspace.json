{
  "version": 1,
  "projects": {
    "npm": {
      "root": "libs/npm",
      "sourceRoot": "libs/npm/src",
      "projectType": "library",
      "schematics": {},
      "architect": {
        "lint": {
          "builder": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": [
              "libs/npm/**/*.ts",
              "libs/npm/**/*.spec.ts",
              "libs/npm/**/*.spec.tsx",
              "libs/npm/**/*.spec.js",
              "libs/npm/**/*.spec.jsx",
              "libs/npm/**/*.d.ts"
            ]
          }
        },
        "test": {
          "builder": "@nrwl/jest:jest",
          "options": {
            "jestConfig": "libs/npm/jest.config.js",
            "passWithNoTests": true
          }
        },
        "build": {
          "builder": "@nrwl/node:package",
          "options": {
            "outputPath": "dist/libs/npm",
            "tsConfig": "libs/npm/tsconfig.lib.json",
            "packageJson": "libs/npm/package.json",
            "main": "libs/npm/src/index.ts",
            "assets": [
              "libs/npm/*.md",
              {
                "input": "./libs/npm/src",
                "glob": "**/*.!(ts)",
                "output": "./src"
              },
              {
                "input": "./libs/npm",
                "glob": "collection.json",
                "output": "."
              },
              {
                "input": "./libs/npm",
                "glob": "builders.json",
                "output": "."
              }
            ]
          }
        }
      }
    },
    "npm-e2e": {
      "projectType": "application",
      "root": "apps\\npm-e2e",
      "sourceRoot": "apps\\npm-e2e/src",
      "architect": {
        "e2e": {
          "builder": "@nrwl/nx-plugin:e2e",
          "options": {
            "target": "npm:build",
            "npmPackageName": "@nx-plugins/npm",
            "pluginOutputPath": "dist/libs/npm",
            "jestConfig": "apps/npm-e2e/jest.config.js"
          }
        }
      }
    },
